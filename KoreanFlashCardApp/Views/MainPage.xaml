<?xml version="1.0" encoding="utf-8" ?>
<controls:BasePage
    x:Class="KoreanFlashCardApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KoreanFlashCardApp.Controls"
    xmlns:models="clr-namespace:KoreanFlashCardApp.Models"
    xmlns:viewModels="clr-namespace:KoreanFlashCardApp.ViewModels"
    x:DataType="viewModels:MainPageViewModel">

    <ScrollView>
        <Grid Grid.RowDefinitions="Auto, Auto">
            <CollectionView Grid.Row="0" ItemsSource="{Binding Words}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Word">
                        <Grid Grid.ColumnDefinitions="*, *">
                            <Label Text="{Binding Word_Name}" />
                            <Label Grid.Column="1" Text="Test" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout
                Grid.Row="1"
                Padding="30,0"
                Spacing="25">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="185"
                    SemanticProperties.Description="dot net bot in a hovercraft number nine"
                    Source="dotnet_bot.png" />

                <Label
                    MaxLines="3"
                    SemanticProperties.HeadingLevel="Level1"
                    Style="{StaticResource Headline}"
                    Text="{Binding Title}" />

                <Label
                    SemanticProperties.Description="Welcome to dot net Multi platform App U I"
                    SemanticProperties.HeadingLevel="Level2"
                    Style="{StaticResource SubHeadline}"
                    Text="Welcome to &#10;.NET Multi-platform App UI" />

                <Button
                    Command="{Binding TestCommand}"
                    HorizontalOptions="Fill"
                    SemanticProperties.Hint="Counts the number of times you click"
                    Text="Click me" />
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</controls:BasePage>
